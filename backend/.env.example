# 漫AI / ComfyUI Orchestrator - 环境变量示例
# 复制此文件为 .env 并填入真实值

# 应用
APP_NAME="漫AI - 动漫创作Token平台"
VERSION="0.1.0"
DEBUG=true

# 数据库
DATABASE_URL="postgresql+asyncpg://cwo:cwo@localhost:5432/cwo"

# Redis
REDIS_URL="redis://localhost:6379/0"

# MinIO
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="cwo"
MINIO_SECRET_KEY="cwo1234"
MINIO_SECURE=false

# ComfyUI (H100集群地址)
COMFYUI_URL="http://localhost:8188"

# JWT ⚠️ 生产环境必须修改！
SECRET_KEY="CHANGE_ME_IN_PRODUCTION_abc123xyz"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
