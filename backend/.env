# 漫AI - 环境变量
# ⚠️ 复制到 .env 并填入真实值

# 数据库 (开发用 SQLite, 生产用 PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./manai.db
# DATABASE_URL=postgresql+asyncpg://manai:manai123@localhost:5432/manai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT ⚠️ 生产环境必须修改！
SECRET_KEY=CHANGE_MUST_IN_PRODUCTION_2026

# 调试
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ComfyUI / Wan2.1 Colab
# 使用 ngrok tunnel 地址，例如: https://xxxx.ngrok.io
COMFYUI_URL=http://localhost:8188
COMFYUI_API_KEY=
WAN21_COMFYUI_URL=https://unmisanthropically-hithermost-dorla.ngrok-free.dev
WAN21_COMFYUI_API_KEY=

# Wan2.1 自建集群 (生产环境)
WAN21_BASE_URL=http://wan21.internal.manai.com
WAN21_API_KEY=

# 硅基流动 API ⚠️ 必需填入
